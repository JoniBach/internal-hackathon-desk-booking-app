# Deskly database connection (PostgreSQL).
#
# ── Local development ─────────────────────────────────────────────
# Run `docker compose up -d` first, then copy this file to `.env`:
#   cp .env.example .env
# The defaults below match docker-compose.yml, so no edits are needed.
DATABASE_URL="postgresql://deskly:deskly@localhost:5432/deskly?schema=public"
DIRECT_URL="postgresql://deskly:deskly@localhost:5432/deskly?schema=public"

# ── Production (Neon / Vercel Postgres) ──────────────────────────
# Set these in the Vercel project's Environment Variables, NOT here.
#   DATABASE_URL  → the POOLED connection string (host contains "-pooler"),
#                   used by the app at runtime.
#   DIRECT_URL    → the DIRECT connection string, used by Prisma migrations.
# Both are shown in the Neon / Vercel Postgres dashboard. Example shape:
#   DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/deskly?sslmode=require"
#   DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/deskly?sslmode=require"
